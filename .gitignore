# Dependencias
node_modules/

# Secretos y entorno
.env
.env.*
*.pem
*.key

# Datos sensibles / privados (NO subir)
# - leads de despachos
data/waitlist.json
# - cuentas (hashes de contraseña) y secreto de firma de sesiones
data/users.json
data/.session_secret
# - store de embeddings (binario + ids + meta, regenerable con `node embed.mjs`)
data/embeddings.*

# Corpus jurídico masivo y ficheros de trabajo del ingestor (regenerables con
# `node ingest.mjs`). Se excluyen hasta revisar licencia/tamaño para versionarlos.
corpus/boe.json
corpus/_index_leyes.json
corpus/_ingested.json

# Modelos / artefactos pesados
*.gguf
*.bin
*.safetensors

# Logs y temporales
*.log
logs/
*.tmp
tmp/

# Sistema operativo
.DS_Store
Thumbs.db

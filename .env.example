# Lexia — configuración local de ejemplo.
# Copia este archivo a .env y ajústalo a tu entorno:
#   cp .env.example .env
# Las variables ya definidas en el sistema tienen prioridad sobre .env.

# Puerto HTTP de Lexia
PORT=5174

# --- Modelo de chat (servidor local compatible con la API de OpenAI) ---
# Endpoint OpenAI-compatible para chat (LM Studio, llama.cpp server, Ollama, vLLM, SGLang...)
LM_BASE=http://127.0.0.1:1234/v1
# Identificador local del modelo de chat (el nombre depende de tu runtime)
CHAT_MODEL=gemma-3-12b-it

# --- Modelo de embeddings ---
# Endpoint OpenAI-compatible para embeddings. Si se deja vacío, usa LM_BASE.
EMBED_BASE=http://127.0.0.1:1234/v1
# Identificador local del modelo de embeddings multilingüe
EMBED_MODEL=bge-m3

# --- Expansión de consulta (opcional) ---
# Modelo ligero para reescribir/expandir la consulta antes de recuperar
FAST_MODEL=qwen3-8b-instruct
# Activa la expansión de consulta con LLM (1 = sí, 0 = no)
USE_EXPAND=0

# --- Reranker (opcional) ---
# Activa el reranking si hay endpoint disponible (1 = sí, 0 = no)
USE_RERANK=1
# Endpoint del reranker compatible /v1/rerank
RERANK_URL=http://127.0.0.1:1235/v1/rerank

# --- Recuperación ---
# Fuentes finales entregadas al LLM
TOP_K=6
# Candidatos recuperados antes del reranker
RECALL_N=40

# --- API para agentes (opcional) ---
# Token Bearer para proteger /api/agent/*. Vacío = endpoints de agente abiertos en local.
LEXIA_AGENT_TOKEN=
